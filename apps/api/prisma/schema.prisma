generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorStatus {
  PENDING
  APPROVED
  SUSPENDED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentProvider {
  STRIPE
  MOCK
}

/// Admin dispute candidates are currently cancelled bookings, rather than
/// customer-opened claims. A row is claimed before a provider refund so one
/// booking can have only one final administrative decision.
enum DisputeResolutionAction {
  FULL_REFUND
  PARTIAL_REFUND
  REJECT
}

enum DisputeResolutionStatus {
  PROCESSING
  RESOLVED
}

/// B5 — Local payout-request state machine.
///
/// Tracks a vendor's request to withdraw eligible earnings and the
/// admin's response. Transitions are governed by `PayoutsService`:
///
///   REQUESTED → APPROVED → PAID
///   REQUESTED → REJECTED
///   APPROVED  → REJECTED
///
/// The DB enforces "at most one active (REQUESTED/APPROVED) payout
/// per vendor" via a partial unique index — see migration
/// `20260715000300_local_payout_requests`. Marking PAID is purely
/// a local declaration; no provider call, no bank transfer, no
/// payout credentials are stored.
enum PayoutStatus {
  REQUESTED
  APPROVED
  REJECTED
  PAID
}

/// Singleton platform configuration. The database migration constrains
/// the sole row to id=1 so commission changes have one authoritative source.
model PlatformSettings {
  id             Int      @id @default(1)
  commissionRate Decimal  @default(0.10) @db.Decimal(7, 6)
  updatedAt      DateTime @default(now()) @updatedAt
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  passwordHash        String?
  role                UserRole  @default(CUSTOMER)
  phone               String?
  locale              String    @default("ar")
  googleId            String?   @unique
  isLocked            Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  vendorProfile   VendorProfile[]
  bookings        Booking[]           @relation("CustomerBookings")
  reviews         Review[]
  messages        Message[]           @relation("SentMessages")
  notifications   Notification[]
  refreshTokens   RefreshToken[]
  passwordResets  PasswordReset[]

  @@index([role])
  @@index([email])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model VendorProfile {
  id             String       @id @default(cuid())
  userId         String       @unique
  businessName   String
  description    String?
  categoryId     String
  address        String?
  lat            Float?
  lng            Float?
  commissionRate Float        @default(0.10)
  status         VendorStatus @default(PENDING)
  avgRating      Float?       @default(0)
  /// IANA timezone, e.g. "America/Sao_Paulo". Used by the booking engine
  /// to interpret vendor availability windows in the vendor's local time.
  timezone       String       @default("UTC")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category       @relation(fields: [categoryId], references: [id])
  services     Service[]
  bookings     Booking[]      @relation("VendorBookings")
  availability Availability[]
  payouts      PayoutRequest[]

  @@index([status])
  @@index([categoryId])
}

model Category {
  id     String  @id @default(cuid())
  nameAr String
  nameEn String
  icon   String?

  vendors  VendorProfile[]
  services Service[]
}

model Service {
  id              String   @id @default(cuid())
  vendorId        String
  title           String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  durationMinutes Int
  categoryId      String
  /// B5 — Optional absolute http/https image URL. DTO validates protocol + length.
  imageUrl        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  vendor   VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  category Category      @relation(fields: [categoryId], references: [id])
  bookings Booking[]

  @@index([vendorId])
  @@index([categoryId])
  @@index([isActive])
}

model Availability {
  id            String    @id @default(cuid())
  vendorId      String
  dayOfWeek     Int
  startTime     String
  endTime       String
  isException   Boolean   @default(false)
  exceptionDate DateTime?

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId, dayOfWeek])
}

model Booking {
  id                 String        @id @default(cuid())
  customerId         String
  vendorId           String
  serviceId          String
  startTime          DateTime
  endTime            DateTime
  status             BookingStatus  @default(PENDING_PAYMENT)
  priceAtBooking     Decimal       @db.Decimal(10, 2)
  commissionAmount   Decimal       @db.Decimal(10, 2)
  holdExpiresAt      DateTime?
  cancellationReason String?
  cancelledBy        String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  /// Generated column backed by the startTime/endTime range. Managed by
  /// the booking_no_overlap migration. Prisma can SELECT it via raw
  /// queries but cannot mutate it directly.
  timeRange          Unsupported("tstzrange")?

  customer          User               @relation("CustomerBookings", fields: [customerId], references: [id])
  vendor            VendorProfile      @relation("VendorBookings", fields: [vendorId], references: [id])
  service           Service            @relation(fields: [serviceId], references: [id])
  payment           Payment?
  disputeResolution DisputeResolution?
  review            Review?
  messages          Message[]

  @@index([vendorId, startTime, endTime])
  @@index([customerId])
  @@index([status])
}

model Payment {
  id                    String          @id @default(cuid())
  bookingId             String          @unique
  provider              PaymentProvider @default(STRIPE)
  /// Provider-specific identifier (e.g. Stripe PaymentIntent ID, or
  /// our own mock txn id). Unique within a provider, but two providers
  /// can each have their own namespace.
  externalId            String          @unique
  amount                Decimal         @db.Decimal(10, 2)
  currency              String          @default("brl")
  status                PaymentStatus   @default(PENDING)
  refundedAmount        Decimal         @default(0) @db.Decimal(10, 2)
  /// Opaque payload from the provider at create time (e.g. Stripe
  /// client_secret we hand to the frontend).
  clientSecret          String?
  /// Last webhook event we processed for this payment.
  lastEventId           String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([provider, externalId])
}

/// Immutable-in-intent audit record for an administrative resolution. The
/// unique bookingId is the durable concurrency claim; PROCESSING exists only
/// while a requested provider refund is in flight.
model DisputeResolution {
  id              String                  @id @default(cuid())
  bookingId       String                  @unique
  action          DisputeResolutionAction
  amount          Decimal?                @db.Decimal(10, 2)
  reason          String
  status          DisputeResolutionStatus @default(PROCESSING)
  decidedByUserId String
  decidedAt       DateTime                @default(now())
  resolvedAt      DateTime?

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([decidedByUserId])
  @@index([decidedAt])
}

model Review {
  id        String   @id @default(cuid())
  bookingId String   @unique
  userId    String
  rating    Int
  comment   String?
  /// B5 — Defaults to VISIBLE so legacy rows and fresh inserts behave identically.
  moderationStatus     ReviewModerationStatus @default(VISIBLE)
  moderationChangedAt  DateTime?
  moderationNote       String?
  createdAt            DateTime               @default(now())

  booking Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id])
  reports ReviewReport[]

  @@index([userId])
  @@index([moderationStatus])
}

/// B5 — Review-report audit record. Reports are NEVER deleted.
/// Duplicate prevention: UNIQUE (reviewId, reporterUserId); the service
/// maps P2002 → 409 Conflict. Resolution updates this row AND the
/// parent Review.moderationStatus atomically.
model ReviewReport {
  id                 String              @id @default(cuid())
  reviewId           String
  reporterUserId     String
  reason             String
  status             ReviewReportStatus  @default(OPEN)
  /// Resolution audit. All four fields are NULL while OPEN.
  resolutionAction   ReviewReportAction?
  resolutionNote     String?
  resolvedByUserId   String?
  resolvedAt         DateTime?
  reportedAt         DateTime            @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([reviewId, reporterUserId])
  @@index([status])
  @@index([reviewId])
  @@index([reporterUserId])
}

model Message {
  id        String    @id @default(cuid())
  bookingId String
  senderId  String
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User    @relation("SentMessages", fields: [senderId], references: [id])

  @@index([bookingId])
  @@index([senderId])
}

/// B5 — Local payout-request record. Money stored as DECIMAL(10,2).
/// No provider, external payout id, account number, IBAN, PIX key, or
/// any payout credential lives on this row. See `PayoutStatus` enum
/// doc-comment for the state machine.
model PayoutRequest {
  id                String       @id @default(cuid())
  vendorId          String
  /// Requested amount in major units (e.g. 100.50). Always > 0.
  amount            Decimal      @db.Decimal(10, 2)
  /// MVP currency is fixed to BRL. The DB CHECK constraint enforces
  /// this even if a future writer bypasses application validation.
  currency          String       @default("brl")
  status            PayoutStatus @default(REQUESTED)
  /// Optional free-text note supplied by the vendor at request time.
  vendorNote        String?
  /// Optional free-text reason supplied by the admin on APPROVE / REJECT.
  adminReason       String?
  /// Audit fields. Plain strings — not FKs to User — so that purging a
  /// user for GDPR reasons does not cascade-delete the audit trail.
  requestedByUserId String
  decidedByUserId   String?
  paidByUserId      String?
  requestedAt       DateTime     @default(now())
  decidedAt         DateTime?
  paidAt            DateTime?
  updatedAt         DateTime     @updatedAt

  vendor VendorProfile @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([status])
  @@index([vendorId, requestedAt])
  @@index([vendorId, status])
}

/// B5 — Review moderation lifecycle. New reviews default to VISIBLE;
/// HIDDEN excludes from public list/stats; FLAGGED stays publicly visible
/// pending admin resolution. No row is ever deleted — see ReviewReport.
enum ReviewModerationStatus {
  VISIBLE
  FLAGGED
  HIDDEN
}

/// B5 — Review-report audit states. OPEN → RESOLVED only.
enum ReviewReportStatus {
  OPEN
  RESOLVED
}

/// B5 — Admin resolution outcomes for an OPEN report.
enum ReviewReportAction {
  KEEP_VISIBLE
  HIDE
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  payload   Json
  readAt    DateTime?
  createdAt DateTime  @default(now())
  /// Stable key used to atomically dedupe in-app notifications at the
  /// database level. Populated by the reminders service with values
  /// like `booking:<bookingId>:reminder:<24h|1h>`. Nullable so
  /// non-reminder notifications (booking confirmed, payment received,
  /// etc.) continue to write rows without a key. Postgres UNIQUE
  /// indexes treat NULL as distinct, so existing rows are unaffected.
  dedupeKey String?   @unique

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}
