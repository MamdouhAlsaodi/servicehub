# ServiceHub API — environment variables
# Copy this file to .env and fill in real values.
#
# === Tests ===
# For the Jest suite, copy `.env.test.example` to `.env.test` and run
# `npm run db:test:reset` to provision the dedicated test database
# (`servicehub_test`). The test process refuses to start if
# DATABASE_URL targets a non-test database. See
# docs/test-database-lifecycle.md for the full procedure.

# === Database ===
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# === Server ===
PORT=3001

# === Auth ===
# Generate with: openssl rand -hex 32
# Must be explicitly set. Production rejects placeholders and values under 32 characters.
JWT_SECRET=replace-with-a-strong-random-secret-at-least-32-characters

# === CORS ===
# Comma-separated exact origins. Required in production.
ALLOWED_ORIGINS=http://localhost:3000

# === Payments ===
# Which provider to use: 'mock' (default, no keys) or 'stripe' (production)
PAYMENTS_PROVIDER=mock

# Stripe credentials (only needed when PAYMENTS_PROVIDER=stripe)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Mock provider — override the webhook signing secret in dev
PAYMENTS_MOCK_WEBHOOK_SECRET=mock-webhook-secret-dev-only

# === Development seed ===
# Required by `npx prisma db seed`; choose non-empty local development values.
# Do not commit real password values.
SEED_ADMIN_PASSWORD=replace-with-local-admin-password
SEED_VENDOR_PASSWORD=replace-with-local-vendor-password
SEED_CUSTOMER_PASSWORD=replace-with-local-customer-password
SEED_DEMO_VENDOR_PASSWORD=replace-with-local-demo-vendor-password
SEED_DEMO_CUSTOMER_PASSWORD=replace-with-local-demo-customer-password
